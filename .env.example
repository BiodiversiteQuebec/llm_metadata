OPENAI_API_KEY=your_openai_api_key
OPENAI_UPSTREAM_BASE=https://api.openai.com                     # Proxy upstream OpenAI endpoint
ZENODO_ACCESS_TOKEN=your_zenodo_token          # Optional, for Zenodo features only
SEMANTIC_SCHOLAR_API_KEY=your_ss_api_key       # Optional, enables dedicated 1 RPS limit
SEMANTIC_SCHOLAR_UPSTREAM_BASE=https://api.semanticscholar.org/graph/v1            # Proxy upstream Semantic Scholar endpoint
